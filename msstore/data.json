[
  {
    "id": "com.arcade.mini-mario",
    "name": "Mini Mario",
    "sub": "Tiny platformer — Arrow keys to move, Z to jump",
    "icon": "https://via.placeholder.com/128/4f46e5/ffffff?text=M",
    "banner": "https://via.placeholder.com/900x200/06b6d4/ffffff?text=Mini+Mario",
    "html": "<style>html,body{height:100%;margin:0;font-family:system-ui,Segoe UI,Roboto,Arial;background:#e6f0ff}#game{display:flex;align-items:center;justify-content:center;height:100%}canvas{background:#87ceeb;border-radius:8px;box-shadow:0 6px 20px rgba(2,6,23,.12)}</style><div id='game'><canvas id='mario' width='640' height='360'></canvas></div><script>(()=>{const cvs=document.getElementById('mario'),ctx=cvs.getContext('2d');const GRAV=0.6;let keys={};document.addEventListener('keydown',e=>keys[e.key]=true);document.addEventListener('keyup',e=>keys[e.key]=false);class Player{constructor(){this.w=28;this.h=36;this.x=60;this.y=300-this.h;this.vx=0;this.vy=0;this.onGround=false}update(){if(keys.ArrowLeft){this.vx=-3}else if(keys.ArrowRight){this.vx=3}else this.vx=0;if(keys.z||keys.Z||keys.ArrowUp){if(this.onGround){this.vy=-11;this.onGround=false}}this.vy+=GRAV;this.x+=this.vx;this.y+=this.vy;this.collide()}collide(){for(let p of level){if(this.x+this.w>p.x&&this.x<p.x+p.w&&this.y+this.h>p.y&&this.y<p.y+p.h){if(this.vy>0){this.y=p.y-this.h;this.vy=0;this.onGround=true}else if(this.vy<0){this.y=p.y+p.h;this.vy=0}}}if(this.y>cvs.height){this.x=60;this.y=0;this.vy=0}}draw(){ctx.fillStyle='#d946ef';ctx.fillRect(this.x,this.y,this.w,this.h)}}class Platform{constructor(x,y,w,h){this.x=x;this.y=y;this.w=w;this.h=h}draw(){ctx.fillStyle='#6b7280';ctx.fillRect(this.x,this.y,this.w,this.h)}}const level=[];function build(){level.length=0;level.push(new Platform(0,320,640,40));level.push(new Platform(120,260,120,16));level.push(new Platform(300,220,100,16));level.push(new Platform(440,180,120,16));level.push(new Platform(520,120,80,16));}build();const player=new Player();function loop(){ctx.clearRect(0,0,cvs.width,cvs.height);for(let p of level)p.draw();player.update();player.draw();requestAnimationFrame(loop)}loop();})();</script>"
  },
  {
    "id": "com.arcade.pacman",
    "name": "Mini Pac-Man",
    "sub": "Arrow keys to move — collect dots, avoid ghosts",
    "icon": "https://via.placeholder.com/128/06b6d4/ffffff?text=P",
    "banner": "https://via.placeholder.com/900x200/4f46e5/ffffff?text=Pac-Man",
    "html": "<style>html,body{height:100%;margin:0;font-family:system-ui;background:#000;color:#fff}#wrap{display:flex;align-items:center;justify-content:center;height:100%}canvas{background:#000;border-radius:6px}</style><div id='wrap'><canvas id='pac' width='480' height='480'></canvas></div><script>(()=>{const cvs=document.getElementById('pac'),ctx=cvs.getContext('2d');const TILE=24,ROWS=20,COLS=20;let grid=[];for(let r=0;r<ROWS;r++){grid[r]=[];for(let c=0;c<COLS;c++){grid[r][c]= (r===0||c===0||r===ROWS-1||c===COLS-1|| (r%2===0&&c%2===0))?1:0}}let dots=new Set();for(let r=1;r<ROWS-1;r++)for(let c=1;c<COLS-1;c++)if(grid[r][c]===0)dots.add(r+','+c);let pac={r:10,c:10,dir:[0,0],speed:0.12,px:10*TILE,py:10*TILE};let ghosts=[{r:8,c:8,px:8*TILE,py:8*TILE,dir:[1,0],color:'#ff3b3b'},{r:12,c:12,px:12*TILE,py:12*TILE,dir:[-1,0],color:'#ffb86b'}];document.addEventListener('keydown',e=>{if(e.key==='ArrowUp')pac.dir=[0,-1];if(e.key==='ArrowDown')pac.dir=[0,1];if(e.key==='ArrowLeft')pac.dir=[-1,0];if(e.key==='ArrowRight')pac.dir=[1,0]});function update(dt){pac.px+=pac.dir[0]*pac.speed*dt;pac.py+=pac.dir[1]*pac.speed*dt;let pr=Math.round(pac.py/TILE),pc=Math.round(pac.px/TILE);if(grid[pr]&&grid[pr][pc]===0){dots.delete(pr+','+pc)}for(let g of ghosts){let dx=pac.px-g.px,dy=pac.py-g.py;let dist=Math.hypot(dx,dy);if(dist<12){reset();return}let step=(Math.random()<0.02)?(Math.random()<0.5?-1:1):1;g.px+=g.dir[0]*0.08*dt*step;g.py+=g.dir[1]*0.08*dt*step;if(Math.random()<0.01)g.dir=[Math.sign(Math.random()-0.5),Math.sign(Math.random()-0.5)];}}function reset(){pac.px=10*TILE;pac.py=10*TILE;pac.dir=[0,0];dots=new Set();for(let r=1;r<ROWS-1;r++)for(let c=1;c<COLS-1;c++)if(grid[r][c]===0)dots.add(r+','+c)}let last=0;function draw(){ctx.clearRect(0,0,cvs.width,cvs.height);ctx.fillStyle='#111';ctx.fillRect(0,0,cvs.width,cvs.height);for(let r=0;r<ROWS;r++)for(let c=0;c<COLS;c++)if(grid[r][c]===1){ctx.fillStyle='#223';ctx.fillRect(c*TILE,r*TILE,TILE,TILE)}ctx.fillStyle='#ffd54f';dots.forEach(k=>{const [r,c]=k.split(',').map(Number);ctx.fillRect(c*TILE+TILE/2-2,r*TILE+TILE/2-2,4,4)});ctx.fillStyle='#ffe082';ctx.beginPath();ctx.arc(pac.px+TILE/2,pac.py+TILE/2,TILE/2-2,0,Math.PI*2);ctx.fill();for(let g of ghosts){ctx.fillStyle=g.color;ctx.beginPath();ctx.arc(g.px+TILE/2,g.py+TILE/2,TILE/2-2,0,Math.PI*2);ctx.fill()}requestAnimationFrame(t=>{let dt=(t-last)||16;last=t;update(dt);draw()});}draw();})();</script>"
  },
  {
    "id": "com.arcade.pong",
    "name": "Pong",
    "sub": "Classic two-player Pong — W/S and Up/Down",
    "icon": "https://via.placeholder.com/128/ef4444/ffffff?text=O",
    "banner": "https://via.placeholder.com/900x200/f97316/ffffff?text=Pong",
    "html": "<style>html,body{height:100%;margin:0;background:#071029;color:#fff;font-family:system-ui}#wrap{display:flex;align-items:center;justify-content:center;height:100%}canvas{background:#001;box-shadow:0 6px 20px rgba(2,6,23,.2);border-radius:6px}</style><div id='wrap'><canvas id='pong' width='640' height='360'></canvas></div><script>(()=>{const cvs=document.getElementById('pong'),ctx=cvs.getContext('2d');let up=false,down=false,wu=false,wd=false;document.addEventListener('keydown',e=>{if(e.key==='ArrowUp')up=true;if(e.key==='ArrowDown')down=true;if(e.key==='w')wu=true;if(e.key==='s')wd=true});document.addEventListener('keyup',e=>{if(e.key==='ArrowUp')up=false;if(e.key==='ArrowDown')down=false;if(e.key==='w')wu=false;if(e.key==='s')wd=false});const P={w:10,h:70,lx:10,rx:cvs.width-20,ly:(cvs.height-70)/2,ry:(cvs.height-70)/2,speed:4};let ball={x:cvs.width/2,y:cvs.height/2,vx:3*(Math.random()<0.5?1:-1),vy:2*(Math.random()<0.5?1:-1),r:7};function reset(){ball.x=cvs.width/2;ball.y=cvs.height/2;ball.vx=3*(Math.random()<0.5?1:-1);ball.vy=2*(Math.random()<0.5?1:-1)}function loop(){ctx.clearRect(0,0,cvs.width,cvs.height);ctx.fillStyle='#fff';ctx.fillRect(P.lx,P.ly,P.w,P.h);ctx.fillRect(P.rx,P.ry,P.w,P.h);ctx.beginPath();ctx.arc(ball.x,ball.y,ball.r,0,Math.PI*2);ctx.fill();ball.x+=ball.vx;ball.y+=ball.vy;if(ball.y<ball.r||ball.y>cvs.height-ball.r)ball.vy*=-1;if(ball.x< P.lx+P.w+ball.r){if(ball.y> P.ly && ball.y< P.ly+P.h){ball.vx*=-1;ball.x=P.lx+P.w+ball.r}else reset()}if(ball.x> P.rx-ball.r){if(ball.y> P.ry && ball.y< P.ry+P.h){ball.vx*=-1;ball.x=P.rx-ball.r}else reset()}if(up)P.ry-=P.speed;if(down)P.ry+=P.speed;if(wu)P.ly-=P.speed;if(wd)P.ly+=P.speed;P.ly=Math.max(0,Math.min(cvs.height-P.h,P.ly));P.ry=Math.max(0,Math.min(cvs.height-P.h,P.ry));requestAnimationFrame(loop)}loop();})();</script>"
  },
  {
    "id": "com.arcade.snake",
    "name": "Snake",
    "sub": "Arrow keys — grow the snake, avoid walls",
    "icon": "https://via.placeholder.com/128/10b981/ffffff?text=S",
    "banner": "https://via.placeholder.com/900x200/059669/ffffff?text=Snake",
    "html": "<style>html,body{height:100%;margin:0;background:#0b1220;color:#fff;font-family:system-ui}#wrap{display:flex;align-items:center;justify-content:center;height:100%}canvas{background:#071029;border-radius:6px}</style><div id='wrap'><canvas id='snake' width='480' height='480'></canvas></div><script>(()=>{const cvs=document.getElementById('snake'),ctx=cvs.getContext('2d');const CELL=20,COLS=24,ROWS=24;let dir=[1,0],snake=[{x:6,y:12},{x:5,y:12},{x:4,y:12}],food=randomFood();document.addEventListener('keydown',e=>{if(e.key==='ArrowUp'&&dir[1]!==1)dir=[0,-1];if(e.key==='ArrowDown'&&dir[1]!==-1)dir=[0,1];if(e.key==='ArrowLeft'&&dir[0]!==1)dir=[-1,0];if(e.key==='ArrowRight'&&dir[0]!==-1)dir=[1,0]});function randomFood(){let p;while(true){p={x:Math.floor(Math.random()*COLS),y:Math.floor(Math.random()*ROWS)};if(!snake.some(s=>s.x===p.x&&s.y===p.y))return p}}function step(){const head={x:snake[0].x+dir[0],y:snake[0].y+dir[1]};if(head.x<0||head.x>=COLS||head.y<0||head.y>=ROWS||snake.some(s=>s.x===head.x&&s.y===head.y)){snake=[{x:6,y:12},{x:5,y:12},{x:4,y:12}];dir=[1,0];food=randomFood();return}snake.unshift(head);if(head.x===food.x&&head.y===food.y){food=randomFood()}else snake.pop()}function draw(){ctx.fillStyle='#071029';ctx.fillRect(0,0,cvs.width,cvs.height);ctx.fillStyle='#10b981';for(let s of snake)ctx.fillRect(s.x*CELL+1,s.y*CELL+1,CELL-2,CELL-2);ctx.fillStyle='#ffcc00';ctx.fillRect(food.x*CELL+4,food.y*CELL+4,CELL-8,CELL-8)}setInterval(()=>{step();draw()},100);draw();})();</script>"
  },
  {
    "id": "com.arcade.breakout",
    "name": "Breakout",
    "sub": "Classic brick breaker — Arrow keys to move paddle",
    "icon": "https://via.placeholder.com/128/f59e0b/ffffff?text=B",
    "banner": "https://via.placeholder.com/900x200/f97316/ffffff?text=Breakout",
    "html": "<style>html,body{height:100%;margin:0;background:#071029;color:#fff;font-family:system-ui}#wrap{display:flex;align-items:center;justify-content:center;height:100%}canvas{background:#001;box-shadow:0 6px 20px rgba(2,6,23,.2);border-radius:6px}</style><div id='wrap'><canvas id='break' width='640' height='360'></canvas></div><script>(()=>{const cvs=document.getElementById('break'),ctx=cvs.getContext('2d');let paddle={w:80,h:12,x:(cvs.width-80)/2,y:cvs.height-30,speed:6},ball={x:cvs.width/2,y:cvs.height-60,r:8,vx:3,vy:-3};let bricks=[];const ROWS=5,COLS=8;for(let r=0;r<ROWS;r++){for(let c=0;c<COLS;c++){bricks.push({x:60+c*68,y:40+r*28,w:60,h:20,alive:true})}}let left=false,right=false;document.addEventListener('keydown',e=>{if(e.key==='ArrowLeft')left=true;if(e.key==='ArrowRight')right=true});document.addEventListener('keyup',e=>{if(e.key==='ArrowLeft')left=false;if(e.key==='ArrowRight')right=false});function loop(){ctx.clearRect(0,0,cvs.width,cvs.height);ctx.fillStyle='#fff';ctx.fillRect(paddle.x,paddle.y,paddle.w,paddle.h);ctx.beginPath();ctx.arc(ball.x,ball.y,ball.r,0,Math.PI*2);ctx.fill();ball.x+=ball.vx;ball.y+=ball.vy;if(ball.x<ball.r||ball.x>cvs.width-ball.r)ball.vx*=-1;if(ball.y<ball.r)ball.vy*=-1;if(ball.y>cvs.height){ball.x=cvs.width/2;ball.y=cvs.height-60;ball.vx=3;ball.vy=-3}if(ball.x>paddle.x&&ball.x<paddle.x+paddle.w&&ball.y+ball.r>paddle.y){ball.vy*=-1;ball.y=paddle.y-ball.r}for(let b of bricks)if(b.alive&&ball.x>b.x&&ball.x<b.x+b.w&&ball.y>b.y&&ball.y<b.y+b.h){b.alive=false;ball.vy*=-1}for(let b of bricks)if(b.alive){ctx.fillStyle='#4f46e5';ctx.fillRect(b.x,b.y,b.w,b.h)}if(left)paddle.x-=paddle.speed;if(right)paddle.x+=paddle.speed;paddle.x=Math.max(0,Math.min(cvs.width-paddle.w,paddle.x));requestAnimationFrame(loop)}loop();})();</script>"
  }
]
